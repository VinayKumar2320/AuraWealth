# App execution config
PORT=8000
HOST=0.0.0.0

# OpenAI API Key for real-time news & sentiment parsing (optional, falls back to pre-defined AI analysis if blank)
OPENAI_API_KEY=your_openai_api_key_here

# Alpaca API Credentials for paper trading & fractional share brokerage orders (optional, falls back to sandbox execution simulation if blank)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
